{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=AdminServiceDb;User Id=sa;Password=YourPassword@123;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Issuer": "https://fooddelivery.com",
    "Audience": "https://fooddelivery.com/api",
    "SecretKey": "your-secret-key-at-least-32-characters-long!!!!"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/adminservice-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
